(* Content-type: application/vnd.wolfram.mathematica *)

(*** Wolfram Notebook File ***)
(* http://www.wolfram.com/nb *)

Notebook[{

Cell["Gram Matrix \[LongDash] Effective Dimension", "Title"],

Cell["Manthos Karydas", "Subtitle"],

Cell["\
Given a kernel K(x,y), discretize the domain, build G[i,j] = K(x_i, x_j), \
and compute the effective dimension as the number of non-negligible eigenvalues.", "Text"],

(* ------------------------------------------------------------------ *)
Cell["Kernel Functions", "Section"],

Cell["Linear:  K(x,y) = x y", "Text"],
Cell[BoxData[
"gramLinear[pts_] := Outer[Times, N[pts], N[pts]]"
], "Input"],

Cell["Polynomial:  K(x,y) = (x y + c)^d", "Text"],
Cell[BoxData[
"gramPolynomial[c_, d_][pts_] := (Outer[Times, N[pts], N[pts]] + c)^d"
], "Input"],

Cell["Gaussian:  K(x,y) = exp(-(x-y)^2 / 2\[Sigma]^2)", "Text"],
Cell[BoxData[
"gramGaussian[sigma_][pts_] :=\n  Exp[-Outer[(#1 - #2)^2 &, N[pts], N[pts]] / (2. sigma^2)]"
], "Input"],

Cell["Laplacian:  K(x,y) = exp(-|x-y| / \[Sigma])", "Text"],
Cell[BoxData[
"gramLaplacian[sigma_][pts_] :=\n  Exp[-Outer[Abs[#1 - #2] &, N[pts], N[pts]] / sigma]"
], "Input"],

Cell["Custom kernel (any function f[x,y]):", "Text"],
Cell[BoxData[
"gramCustom[kernel_][pts_] := N @ Outer[kernel, pts, pts, 1]"
], "Input"],

(* ------------------------------------------------------------------ *)
Cell["Discretize Domain", "Section"],

Cell[BoxData[
"discretize[{a_, b_}, n_] := N @ Subdivide[a, b, n - 1]"
], "Input"],

(* ------------------------------------------------------------------ *)
Cell["Effective Dimension", "Section"],

Cell["\
Counts eigenvalues above a threshold.\n\
  relative = True  (default): cutoff = threshold \[Times] \[Lambda]max\n\
  relative = False: absolute cutoff\n\
Returns {effectiveDim, eigenvalues} in descending order.", "Text"],

Cell[BoxData[
"effectiveDimension[G_, threshold_ : 1*^-6, relative_ : True] :=\n  Module[{eigs, cutoff},\n    eigs   = Sort[Eigenvalues[N[G]], Greater];\n    cutoff = If[relative, threshold * First[eigs], threshold];\n    {Count[eigs, e_ /; e > cutoff], eigs}\n  ]"
], "Input"],

(* ------------------------------------------------------------------ *)
Cell["Example", "Section"],

Cell[BoxData[
"points = discretize[{0., 1.}, 50];"
], "Input"],

Cell[BoxData[
"kernels = {\n  {\"Linear\",          gramLinear},\n  {\"Polynomial d=2\",  gramPolynomial[1, 2]},\n  {\"Polynomial d=5\",  gramPolynomial[1, 5]},\n  {\"Gaussian s=1.0\",  gramGaussian[1.0]},\n  {\"Gaussian s=0.1\",  gramGaussian[0.1]},\n  {\"Gaussian s=0.01\", gramGaussian[0.01]}\n};"
], "Input"],

Cell[BoxData[
"results = Table[\n  Module[{G, dim, eigs},\n    G = row[[2]][points];\n    {dim, eigs} = effectiveDimension[G];\n    {row[[1]], dim, First[eigs],\n     Min @ Select[eigs, # > 1*^-6 * First[eigs] &]}\n  ],\n  {row, kernels}\n];\n\nTableForm[results,\n  TableHeadings -> {None, {\"Kernel\", \"Eff. dim\", \"\[Lambda]max\", \"\[Lambda]min\"}}]"
], "Input"]

}, WindowSize -> {900, 800},
   WindowMargins -> {{Automatic, Automatic}, {Automatic, Automatic}},
   StyleDefinitions -> "Default.nb"
]
